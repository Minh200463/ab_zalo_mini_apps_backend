DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zalo_miniapp?appName=Cluster0
PAYLOAD_SECRET=<chuoi-64-hex-ngau-nhien>

# --- S3 lưu ảnh (tùy chọn). Có S3_BUCKET => bật S3; bỏ trống => lưu ổ đĩa local ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Chỉ cho S3-compatible (MinIO / Cloudflare R2 / Wasabi...). AWS S3 thì để trống.
S3_ENDPOINT=
# MinIO / một số dịch vụ cần true (path-style). AWS/R2 thường để trống/false.
S3_FORCE_PATH_STYLE=
